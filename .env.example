# Copy to .env for local use. Do not commit real .env files.

COMPOSE_PROJECT_NAME=inspection_pwa

# Runtime bind mounts on the client Windows PC.
INSPECTION_UPLOADS_PATH=C:/InspectionSystem/runtime/uploads
INSPECTION_API_LOGS_PATH=C:/InspectionSystem/runtime/logs/api
INSPECTION_PROXY_LOGS_PATH=C:/InspectionSystem/runtime/logs/proxy
INSPECTION_BACKUPS_PATH=C:/InspectionSystem/runtime/backups
INSPECTION_RESTORE_STAGING_PATH=C:/InspectionSystem/runtime/restore-staging
INSPECTION_OPERATIONAL_PATH=C:/InspectionSystem/runtime/operational

# Placeholder host for local skeleton validation only.
PUBLIC_HOSTNAME=localhost

# Replace these outside Git before real use.
POSTGRES_DB=inspection
POSTGRES_USER=inspection_app
POSTGRES_PASSWORD=replace-with-a-real-secret-outside-git
DATABASE_URL=postgres://inspection_app:replace-with-a-real-secret-outside-git@postgres:5432/inspection

API_PORT=3000
NODE_ENV=production

